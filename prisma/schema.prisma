// Multi-client Business Management Platform
// Covers: platform admin (clients/onboarding), auth/roles, menu, tables, orders,
// billing & payments, basic inventory, staff management, external order intake.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BusinessType {
  RESTAURANT
  CAFE
  CAKE_BAKERY
  CLOUD_KITCHEN
  BAR_PUB
  FOOD_TRUCK
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  CHEF
  ACCOUNTANT
  DELIVERY
  HELPER
}

enum OrderSource {
  POS
  WEBSITE
  SWIGGY
  ZOMATO
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
}

enum LeaveType {
  SICK
  CASUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  PAID
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum KitchenStatus {
  PENDING
  COOKING
  READY
  SERVED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

/// A business onboarded onto the platform (a "customer" of the platform, e.g. a
/// specific restaurant or cake shop). All operational data below is scoped to one.
model Client {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  businessType BusinessType
  logoUrl      String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Per-client shared secrets for the external-order webhook (one per aggregator).
  // Each client has its own Swiggy/Zomato partner account, so secrets can't be
  // shared platform-wide the way a single env var would imply.
  swiggyWebhookSecret  String @unique @default(cuid())
  zomatoWebhookSecret  String @unique @default(cuid())
  websiteWebhookSecret String @unique @default(cuid())

  users          User[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  ingredients    Ingredient[]
  tables         RestaurantTable[]
  customers      Customer[]
  orders         Order[]
  bills          Bill[]
  coupons        Coupon[]
  staff          Staff[]
  shifts         Shift[]

  @@map("clients")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role?
  isSuperAdmin Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // null only for platform super-admins, who sit above all clients
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ordersServed Order[] @relation("OrderWaiter")
  staff        Staff?

  @@map("users")
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("menu_categories")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  costPrice   Decimal  @default(0) @db.Decimal(10, 2)
  isAvailable Boolean  @default(true)
  isSeasonal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   MenuCategory @relation(fields: [categoryId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  variants          MenuItemVariant[]
  recipeIngredients RecipeIngredient[]
  orderItems        OrderItem[]

  @@map("menu_items")
}

model MenuItemVariant {
  id        String  @id @default(cuid())
  name      String // e.g. Small, Medium, Large / Regular
  price     Decimal @db.Decimal(10, 2)
  isDefault Boolean @default(false)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  @@map("menu_item_variants")
}

model Ingredient {
  id              String   @id @default(cuid())
  name            String
  unit            String // e.g. kg, g, l, ml, pcs
  quantityInStock Decimal  @default(0) @db.Decimal(10, 3)
  reorderLevel    Decimal  @default(0) @db.Decimal(10, 3)
  costPerUnit     Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  recipeIngredients RecipeIngredient[]

  @@map("ingredients")
}

model RecipeIngredient {
  id               String  @id @default(cuid())
  quantityRequired Decimal @db.Decimal(10, 3)

  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, ingredientId])
  @@map("recipe_ingredients")
}

model RestaurantTable {
  id       String      @id @default(cuid())
  name     String // e.g. T1, T2
  floor    String      @default("Floor 1")
  capacity Int         @default(2)
  status   TableStatus @default(AVAILABLE)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  orders Order[]

  @@unique([clientId, name])
  @@map("restaurant_tables")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String?
  loyaltyPoints Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  orders Order[]

  @@unique([clientId, phone])
  @@map("customers")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String
  type            OrderType   @default(DINE_IN)
  status          OrderStatus @default(PENDING)
  source          OrderSource @default(POS)
  externalOrderId String?
  subtotal        Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  tableId String?
  table   RestaurantTable? @relation(fields: [tableId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  waiterId String?
  waiter   User?   @relation("OrderWaiter", fields: [waiterId], references: [id])

  items    OrderItem[]
  bill     Bill?
  payments Payment[]

  @@unique([clientId, orderNumber])
  @@unique([clientId, source, externalOrderId])
  @@map("orders")
}

model OrderItem {
  id            String        @id @default(cuid())
  quantity      Int           @default(1)
  unitPrice     Decimal       @db.Decimal(10, 2)
  totalPrice    Decimal       @db.Decimal(10, 2)
  notes         String?
  kitchenStatus KitchenStatus @default(PENDING)
  createdAt     DateTime      @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  variantId String?
  variant   MenuItemVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Bill {
  id             String   @id @default(cuid())
  billNumber     String
  subtotal       Decimal  @db.Decimal(10, 2)
  taxRate        Decimal  @default(5) @db.Decimal(5, 2)
  taxAmount      Decimal  @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  couponCode     String?
  totalAmount    Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  @@unique([clientId, billNumber])
  @@map("bills")
}

model Payment {
  id             String        @id @default(cuid())
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  transactionRef String?
  paidAt         DateTime      @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Coupon {
  id        String     @id @default(cuid())
  code      String
  type      CouponType
  value     Decimal    @db.Decimal(10, 2)
  isActive  Boolean    @default(true)
  expiresAt DateTime?
  createdAt DateTime   @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, code])
  @@map("coupons")
}

model Staff {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  role        Role
  baseSalary  Decimal  @default(0) @db.Decimal(10, 2)
  joiningDate DateTime @default(now())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  attendance       Attendance[]
  shiftAssignments ShiftAssignment[]
  leaveRequests    LeaveRequest[]
  payrolls         Payroll[]

  @@unique([clientId, phone])
  @@map("staff")
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  clockIn   DateTime?
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("attendance")
}

model Shift {
  id        String @id @default(cuid())
  name      String // e.g. Morning, Evening, Night
  startTime String // "09:00"
  endTime   String // "17:00"

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  assignments ShiftAssignment[]

  @@map("shifts")
}

model ShiftAssignment {
  id   String   @id @default(cuid())
  date DateTime @db.Date

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@map("shift_assignments")
}

model LeaveRequest {
  id        String      @id @default(cuid())
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  type      LeaveType
  status    LeaveStatus @default(PENDING)
  reason    String?
  createdAt DateTime    @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("leave_requests")
}

model Payroll {
  id          String        @id @default(cuid())
  month       Int // 1-12
  year        Int
  baseSalary  Decimal       @db.Decimal(10, 2)
  incentives  Decimal       @default(0) @db.Decimal(10, 2)
  overtimePay Decimal       @default(0) @db.Decimal(10, 2)
  deductions  Decimal       @default(0) @db.Decimal(10, 2)
  netPay      Decimal       @db.Decimal(10, 2)
  status      PayrollStatus @default(DRAFT)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, month, year])
  @@map("payrolls")
}
